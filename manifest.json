{
  "manifest_version": 3,
  "name": "Token Compressor",
  "version": "1.0.0",
  "description": "Compresses your prompts client-side before they're sent to ChatGPT, Claude, or Copilot Chat. Zero network calls, no telemetry.",
  "permissions": ["storage", "unlimitedStorage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://github.com/*",
    "https://copilot.microsoft.com/*"
  ],
  "background": {
    "service_worker": "dist/service-worker.bundle.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://github.com/*",
        "https://copilot.microsoft.com/*"
      ],
      "js": ["src/content/lib-core.js", "src/content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/hud.css"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://github.com/*",
        "https://copilot.microsoft.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
