# dist/service-worker.bundle.js is a BUILD OUTPUT (generated by `npm run
# build`), not source — but manifest.json requires it to exist for
# "Load unpacked" to work. It's intentionally NOT ignored here so the
# repo/zip stays loadable out of the box; run `npm run build` after any
# change to src/background/*.js and commit the refreshed bundle, or add
# dist/service-worker.bundle.js to this file if your workflow always
# builds before loading.
